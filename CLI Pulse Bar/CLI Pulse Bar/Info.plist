	<key>CFBundleLocalizations</key>
	<array>
		<!-- v1.21 D8: explicit list so iOS's locale matcher falls back
		     zh-Hant → zh-Hans (same script family) instead of dropping to en.
		     Listing zh-Hant here without a zh-Hant.lproj is intentional —
		     Apple's locale chain matches scripts; absent lproj triggers
		     fallback to zh-Hans. Adding an empty zh-Hant.lproj would risk
		     ASC 4.0 "Incomplete Localization" review reject. -->
